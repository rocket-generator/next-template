BETTER_AUTH_BASE_URL=http://localhost:3000
BETTER_AUTH_SECRET=[BETTER_AUTH_SECRET] # Replace with your Better Auth secret
NEXT_PUBLIC_BETTER_AUTH_BASE_PATH=/api/auth

NEXT_PUBLIC_SERVICE_NAME="TypeScript Next Template"
NEXT_PUBLIC_SERVICE_DESCRIPTION="Full-stack template built with TypeScript and Next.js."

NEXT_SERVER_COMPONENT_BACKEND_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_CLIENT_COMPONENT_BACKEND_API_BASE_URL=http://localhost:8000/api

AIRTABLE_API_KEY=
AIRTABLE_APP_ID=

# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/your-database-name?schema=public"

# AWS S3 / SES Configuration (SYSTEM_ prefix required for Amplify compatibility)
SYSTEM_AWS_S3_REGION=us-east-1
SYSTEM_AWS_SES_REGION=us-east-1
SYSTEM_AWS_ACCESS_KEY_ID=your-aws-access-key-id
SYSTEM_AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
SYSTEM_AWS_S3_BUCKET=my-app-bucket
EMAIL_FROM=noreply@yourdomain.com
SES_FROM_EMAIL=noreply@yourdomain.com # deprecated: use EMAIL_FROM instead

# LocalStack Configuration (Development)
# Use these values for local development with LocalStack
LOCALSTACK_ENDPOINT=http://localhost:4566
LOCALSTACK_PUBLIC_ENDPOINT=http://localhost:4566
ENABLE_EMAIL_VERIFICATION=true
# Settings
ENABLE_AUTH_PAGE_REDIRECT=true
ENABLE_AVATAR_SETTING=false
# use LocalStack for local development
USE_LOCALSTACK=true

# Storage provider (s3 | s3-compatible | gcs)
STORAGE_PROVIDER=s3
S3_COMPATIBLE_ENDPOINT=
S3_COMPATIBLE_PUBLIC_ENDPOINT=
S3_COMPATIBLE_FORCE_PATH_STYLE=true
GCS_PROJECT_ID=
GCS_BUCKET=
GCS_CLIENT_EMAIL=
GCS_PRIVATE_KEY=
GCS_REGION=

# Email provider (ses | smtp)
EMAIL_PROVIDER=ses
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# DB TLS settings
# DATABASE_SSL_REJECT_UNAUTHORIZED=true # set to "false" to disable certificate verification (not recommended)
# DATABASE_SSL_CA_PATH= # standard CA file path for Docker / VM / ECS / Kubernetes / Amplify. Optional.
# DATABASE_SSL_CA= # inline PEM override for env-only deployments. Takes priority over DATABASE_SSL_CA_PATH.

# Additional remote image URL prefixes (CSV of absolute URLs)
# Examples:
# EXTRA_REMOTE_IMAGE_URLS=https://cdn.example.com,https://images.example.com/account123/,http://localhost:9000/my-bucket/
EXTRA_REMOTE_IMAGE_URLS=
