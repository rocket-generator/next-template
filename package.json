{
  "name": "frontend",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:storybook": "playwright test -c playwright.storybook.config.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset --force && npm run db:generate && npm run db:seed",
    "db:setup": "npm run db:generate && npm run db:push && npm run db:seed",
    "db:studio": "prisma studio",
    "db:format": "prisma format",
    "docker:db:generate": "docker compose exec -T web npx prisma generate",
    "docker:db:migrate": "docker compose exec -T web npx prisma migrate dev",
    "docker:db:push": "docker compose exec -T web npx prisma db push",
    "docker:db:seed": "docker compose exec -T web npx prisma db seed",
    "docker:db:reset": "docker compose exec -T web npx prisma migrate reset --force && npm run docker:db:generate && npm run docker:db:seed",
    "docker:db:setup": "npm run docker:db:generate && npm run docker:db:push && npm run docker:db:seed",
    "docker:db:studio": "docker compose exec web npx prisma studio"
  },
